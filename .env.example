# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# OpenRouter API key — used to query the surfaces under test
# (Claude, Perplexity, ChatGPT) with web search on. https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — Brave Search API (free tier): reliable Brave index-presence check
# in access-checks.mjs (the Claude-search visibility gate). Without it that one
# check reports indeterminate.
BRAVE_SEARCH_API_KEY=

# Optional — DataForSEO (pay-as-you-go): API-backed mention/SERP facts for the
# evidence ledgers. Everything degrades to agent search without it.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
